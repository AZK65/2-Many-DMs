DATABASE_URL="file:./dev.db"

# --- Telegram (GramJS / MTProto) ---
# Get api_id + api_hash from https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Filled in by `npm run tg:login` (one-time phone login).
TELEGRAM_SESSION=

# --- WhatsApp ---
WHATSAPP_ENABLED=
# Driver: "baileys" = browser-free WebSocket (~20-40MB/account, best for
# multi-account); blank/"web" = whatsapp-web.js + Chromium (~400MB).
WHATSAPP_DRIVER=baileys
# Optional: pin a known-good web build if linking fails. Newest filename from
# https://github.com/wppconnect-team/wa-version/tree/main/html (without .html)
WHATSAPP_WEB_VERSION=
# How many of your most-recent WhatsApp DMs to import on first link.
WHATSAPP_BACKFILL_CHATS=20

# --- X / Twitter ---
X_ENABLED=
# Driver: "api" = browser-free, reads CLASSIC DMs via cookies (cheap); blank/
# "browser" = Puppeteer XChat (encrypted DMs, heavy). Both use X_AUTH_TOKEN/X_CT0.
X_DRIVER=api
X_POLL_MS=20000
X_BACKFILL_CHATS=20
# Bypass X login bot-detection: paste auth_token + ct0 cookies from your browser
# (DevTools -> Application -> Cookies -> https://x.com), or use the Chrome extension.
X_AUTH_TOKEN=
X_CT0=
X_CHROME_CHANNEL=
# XChat (encrypted DMs) passcode — unlocks decryption keys in the browser.
X_PASSCODE=

# --- Sync worker ---
SYNC_CONTROL_PORT=4001
SYNC_CONTROL_URL=http://localhost:4001
SYNC_BACKFILL=1
SYNC_BACKFILL_DIALOGS=30
SYNC_BACKFILL_MESSAGES=20
MEDIA_MAX_MB=25

# --- Security ---
# 32-byte key (64 hex chars) used to encrypt stored login sessions at rest.
# Generate with:  openssl rand -hex 32
# REQUIRED in production (the app refuses to start without it when NODE_ENV=production).
APP_ENCRYPTION_KEY=

# --- Hosting (Railway / Docker) ---
# Where to persist DB + login sessions (Railway: mount a volume at /data).
# DATA_DIR=/data
# DATABASE_URL="file:/data/dev.db"
# Route the WhatsApp + X browsers through a sticky RESIDENTIAL proxy that is
# geo-matched to where the account normally logs in. Leave empty for direct.
# PROXY_URL=http://user:pass@host:port
# Use the system Chromium in Docker (set by the Dockerfile).
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
